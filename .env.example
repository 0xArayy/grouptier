# Telegram bot token from @BotFather
BOT_TOKEN=

# Full Railway Postgres URL (automatically set by Railway addon)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# t.me link to the Mini App (from BotFather /newapp), e.g. https://t.me/your_bot/appname
MINI_APP_TGLINK=https://t.me/your_bot/appname

# Set to "production" on Railway
NODE_ENV=production

# Railway sets this automatically; local default is 3000
PORT=3000
