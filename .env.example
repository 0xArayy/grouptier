# Telegram bot token from @BotFather
BOT_TOKEN=

# Full Railway Postgres URL (automatically set by Railway addon)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# HTTPS URL where the Mini App is served (same as your Railway deploy URL)
MINI_APP_URL=https://your-app.up.railway.app

# Set to "production" on Railway
NODE_ENV=production

# Railway sets this automatically; local default is 3000
PORT=3000
